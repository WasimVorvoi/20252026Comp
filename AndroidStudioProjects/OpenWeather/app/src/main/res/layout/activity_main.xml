<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_horizontal">

            <!-- SEARCH BAR CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="52dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="#10131A"
                app:strokeColor="#1F2937"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilZip"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="ZIP Code"
                        app:hintTextColor="#9CA3AF"
                        app:boxStrokeColor="#22C55E"
                        app:boxStrokeErrorColor="#EF4444"
                        app:boxBackgroundColor="#0B0F14"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusBottomEnd="16dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etZipCode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:maxLength="5"
                            android:imeOptions="actionSearch"
                            android:singleLine="true"
                            android:textColor="#E5E7EB"
                            android:textColorHint="#6B7280"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSearch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="RUN"
                        android:textAllCaps="true"
                        android:textColor="#06110A"
                        app:cornerRadius="16dp"
                        app:backgroundTint="#22C55E"
                        app:rippleColor="#5EEAD4"/>
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- WEATHER CARD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/weatherCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:visibility="gone"
                app:cardCornerRadius="24dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="#0F172A"
                app:strokeColor="#0EA5E9"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:id="@+id/tvCity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#E5E7EB"
                        tools:text="Newark, NJ"/>

                    <TextView
                        android:id="@+id/tvDateTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textSize="13sp"
                        android:textColor="#94A3B8"
                        tools:text="Mon 9:41 AM"/>

                    <TextView
                        android:id="@+id/tvTemp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textSize="80sp"
                        android:textStyle="bold"
                        android:textColor="#5EEAD4"
                        android:gravity="center"
                        tools:text="72°"/>

                    <TextView
                        android:id="@+id/tvCondition"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:textColor="#A7F3D0"
                        android:gravity="center"
                        android:letterSpacing="0.08"
                        tools:text="PARTLY CLOUDY"/>

                    <TextView
                        android:id="@+id/tvHighLow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textSize="18sp"
                        android:textColor="#E5E7EB"
                        android:gravity="center"
                        tools:text="H: 78°  •  L: 61°"/>

                    <TextView
                        android:id="@+id/tvFeelsLike"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textSize="14sp"
                        android:textColor="#94A3B8"
                        android:gravity="center"
                        tools:text="Feels like 70°"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="16dp"
                        android:background="#1F2937"/>

                    <TextView
                        android:id="@+id/tvPrecip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:textColor="#E5E7EB"
                        tools:text="Precip: 10%  •  Humidity: 48%"/>

                    <TextView
                        android:id="@+id/tvSunInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textSize="15sp"
                        android:textColor="#E5E7EB"
                        tools:text="Sunrise: 6:38 AM  •  Sunset: 5:52 PM"/>
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- FORECAST CARD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/forecastCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:visibility="gone"
                app:cardCornerRadius="24dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="#10131A"
                app:strokeColor="#22C55E"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5-DAY FORECAST"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#94A3B8"
                        android:letterSpacing="0.08"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="4dp"
                        android:background="#1F2937"/>

                    <!-- Row template colors applied; keep your same IDs -->
                    <!-- Day 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvDay1"
                            android:layout_width="44dp"
                            android:layout_height="wrap_content"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#E5E7EB"/>

                        <TextView
                            android:id="@+id/tvFIcon1"
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:textSize="22sp"
                            android:gravity="center"
                            android:textColor="#5EEAD4"/>

                        <TextView
                            android:id="@+id/tvFDesc1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="13sp"
                            android:textColor="#94A3B8"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end">

                            <TextView
                                android:id="@+id/tvFTemps1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#A7F3D0"/>

                            <TextView
                                android:id="@+id/tvFTime1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="11sp"
                                android:textColor="#64748B"/>
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#111827"/>

                    <!-- Apply the SAME textColor updates to Day2-Day5 blocks (below). -->
                    <!-- For brevity: keep your existing structure; just copy the colors from Day1 row to the others. -->

                    <!-- Day 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:id="@+id/tvDay2"
                            android:layout_width="44dp"
                            android:layout_height="wrap_content"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#E5E7EB"/>
                        <TextView
                            android:id="@+id/tvFIcon2"
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:textSize="22sp"
                            android:gravity="center"
                            android:textColor="#5EEAD4"/>
                        <TextView
                            android:id="@+id/tvFDesc2"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="13sp"
                            android:textColor="#94A3B8"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end">
                            <TextView
                                android:id="@+id/tvFTemps2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#A7F3D0"/>
                            <TextView
                                android:id="@+id/tvFTime2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="11sp"
                                android:textColor="#64748B"/>
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#111827"/>

                    <!-- Day 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:id="@+id/tvDay3"
                            android:layout_width="44dp"
                            android:layout_height="wrap_content"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#E5E7EB"/>
                        <TextView
                            android:id="@+id/tvFIcon3"
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:textSize="22sp"
                            android:gravity="center"
                            android:textColor="#5EEAD4"/>
                        <TextView
                            android:id="@+id/tvFDesc3"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="13sp"
                            android:textColor="#94A3B8"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end">
                            <TextView
                                android:id="@+id/tvFTemps3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#A7F3D0"/>
                            <TextView
                                android:id="@+id/tvFTime3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="11sp"
                                android:textColor="#64748B"/>
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#111827"/>

                    <!-- Day 4 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:id="@+id/tvDay4"
                            android:layout_width="44dp"
                            android:layout_height="wrap_content"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#E5E7EB"/>
                        <TextView
                            android:id="@+id/tvFIcon4"
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:textSize="22sp"
                            android:gravity="center"
                            android:textColor="#5EEAD4"/>
                        <TextView
                            android:id="@+id/tvFDesc4"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="13sp"
                            android:textColor="#94A3B8"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end">
                            <TextView
                                android:id="@+id/tvFTemps4"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#A7F3D0"/>
                            <TextView
                                android:id="@+id/tvFTime4"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="11sp"
                                android:textColor="#64748B"/>
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#111827"/>

                    <!-- Day 5 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:id="@+id/tvDay5"
                            android:layout_width="44dp"
                            android:layout_height="wrap_content"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#E5E7EB"/>
                        <TextView
                            android:id="@+id/tvFIcon5"
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:textSize="22sp"
                            android:gravity="center"
                            android:textColor="#5EEAD4"/>
                        <TextView
                            android:id="@+id/tvFDesc5"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="13sp"
                            android:textColor="#94A3B8"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end">
                            <TextView
                                android:id="@+id/tvFTemps5"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#A7F3D0"/>
                            <TextView
                                android:id="@+id/tvFTime5"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="11sp"
                                android:textColor="#64748B"/>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>