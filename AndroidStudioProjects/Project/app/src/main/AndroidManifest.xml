<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        PERMISSIONS EXPLAINED:
        VIBRATE: optional — lets us vibrate the phone on death (not yet implemented, but declared).
    -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!--
        FEATURE DECLARATIONS:
        The game uses the accelerometer sensor. We declare it as "not required" so the
        app can still install on devices without one (it just won't tilt-control correctly).
    -->
    <uses-feature android:name="android.hardware.sensor.accelerometer" android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FrozenEscape"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:hardwareAccelerated="true">
            <!--
                screenOrientation="portrait" : lock to portrait so the game never rotates.
                configChanges: handle orientation/size changes ourselves instead of
                               letting Android recreate the Activity (prevents restarts).
                hardwareAccelerated: use GPU for Canvas drawing (better performance).
            -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
